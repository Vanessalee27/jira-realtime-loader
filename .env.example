# ============================================================
# 環境設定範例檔 —— 請複製為 .env 使用
# 絕對不要在此檔案填入真實 API Key 或密碼
# 系統偵測到下列預設值時，會強制要求管理員於執行時手動輸入
# ============================================================

YOUR_API_KEY=XXXXX

# PDM / Windchill 帳密不放這裡，一律於執行時由管理員手動輸入
# （比照 API Key 治理原則，避免任何形式的明碼落地）
